#!/usr/bin/env bash
set -e

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$DIR"

echo "Building Go sidecar..."
cd sidecar
go build -o ../bin/sidecar
cd ..

if [ ! -d "src/ComfyUI" ]; then
    echo "Cloning ComfyUI from local vendor cache..."
    git clone /Users/jane/work/vendor/cui/ComfyUI src/ComfyUI
fi

cd src/ComfyUI

if [ ! -d ".venv" ]; then
    echo "Creating uv venv and installing dependencies..."
    uv venv
    # Native PyTorch on macOS supports Metal (MPS) out of the box via standard PyPI
    uv pip install torch torchvision torchaudio
    uv pip install -r requirements.txt
    if [ -f "custom_nodes/ComfyUI-GGUF/requirements.txt" ]; then
        uv pip install -r custom_nodes/ComfyUI-GGUF/requirements.txt
    fi
fi

if [ ! -d "custom_nodes/ComfyUI-GGUF" ]; then
    echo "Cloning ComfyUI-GGUF..."
    git clone https://github.com/city96/ComfyUI-GGUF.git custom_nodes/ComfyUI-GGUF
fi
if [ -f "custom_nodes/ComfyUI-GGUF/requirements.txt" ]; then
    uv pip install -r custom_nodes/ComfyUI-GGUF/requirements.txt
fi

# Configure ComfyUI to read the HuggingFace cache directly
# Because this is native Mac, the symlinks in the snapshot
MODEL_PATH="/Users/jane/.cache/huggingface/hub/models--gpustack--stable-diffusion-v3-5-large-GGUF/snapshots/937e5a94fa7679e9a58916217549d07be49b968b"
if [ ! -d "$MODEL_PATH" ]; then
    echo "CRITICAL: Stable Diffusion v3.5 GGUF snapshot not found in HuggingFace cache."
    echo "Please run 'huggingface-cli download gpustack/stable-diffusion-v3-5-large-GGUF' to hydrate the cache before launching."
    exit 1
fi

cat <<EOF > extra_model_paths.yaml
comfyui:
    unet: $MODEL_PATH
EOF

echo "Starting ComfyUI on MPS..."
# We explicitly set --port 8191 and listen locally so Traefik/Sidecar handles ingress
.venv/bin/python main.py --listen 127.0.0.1 --port 8191 --enable-cors-header "*" &
COMFY_PID=$!

echo "Starting Go sidecar (exposing :8190)..."
export TARGET_URL=http://127.0.0.1:8191
export PORT=8190
"$DIR/bin/sidecar" &
SIDECAR_PID=$!

echo "Registering Metal backend with Traefik..."
cat <<EOF > /Users/jane/var/traefik/dynamic/comfyui-metal.yml
http:
  routers:
    comfyui-metal:
      rule: Host(\`comfyui.localhost\`)
      service: comfyui-metal
      priority: 100
  services:
    comfyui-metal:
      loadBalancer:
        servers:
          - url: http://host.docker.internal:8190
EOF

# Cleanup trap so Delightd can cleanly tear down the service
trap "rm -f /Users/jane/var/traefik/dynamic/comfyui-metal.yml; kill $COMFY_PID $SIDECAR_PID" SIGINT SIGTERM EXIT

wait
